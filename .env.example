PORT=3000
DB_FILE=./data/citas.sqlite
SITE_URL=http://localhost:3000
FROM_EMAIL=no-reply@citasapp.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario@example.com
SMTP_PASS=tu_contraseña

# Ejemplo Gmail SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tuemail@gmail.com
# SMTP_PASS=tu_password_o_app_password

# WhatsApp API (opcional)
# Proveedor: 'twilio' o 'meta'
WA_PROVIDER=twilio

# Twilio (si usa Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+1415XXXXXXX

# WhatsApp Cloud API (Meta) (si usa meta)
WA_META_TOKEN=your_facebook_access_token
WA_META_PHONE_ID=your_whatsapp_phone_id
